{
  "name": "@vibe-engineer-starter/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "test:unit": "tsx --test \"test/**/*.test.ts\"",
    "build": "tsc -p tsconfig.json",
    "quality:quick": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test:unit && pnpm run build",
    "dev": "tsx watch src/main.ts",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset:local": "prisma migrate reset --force"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@vibe-engineer-starter/domain": "workspace:^0.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
