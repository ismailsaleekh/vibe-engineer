{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["src/**/*.js", "src/**/*.d.ts"],
  "exclude": ["dist", "node_modules", "tests"]
}
