{
  "name": "@vibe-engineer/artifacts",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "Canonical artifact schemas, generated types, and fail-closed validators for vibe-engineer workflows.",
  "private": false,
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.33.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismailsaleekh/vibe-engineer.git"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/types.d.ts",
      "import": "./dist/schema-registry.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "generate:types": "node scripts/generate-types.mjs",
    "check:types": "node scripts/check-generated-types.mjs",
    "typecheck": "node scripts/check-generated-types.mjs && node scripts/typecheck-public-entrypoint.mjs",
    "test": "node tests/run-tests.mjs",
    "build": "node scripts/generate-types.mjs && tsup"
  },
  "vibeEngineer": {
    "implementationUnit": "I-01A-artifact-schemas",
    "implementationStatus": "v0.1-public-artifact-api",
    "packageRole": "public-artifact-schema-package",
    "sourceStatus": "v0.1-schema-validation-api"
  },
  "dependencies": {
    "ajv": "8.17.1"
  },
  "author": "Ismail <ismailsalikhodjaev@gmail.com>",
  "bugs": {
    "url": "https://github.com/ismailsaleekh/vibe-engineer/issues"
  },
  "homepage": "https://github.com/ismailsaleekh/vibe-engineer#readme",
  "keywords": [
    "ai",
    "agents",
    "typescript",
    "verification",
    "schematics",
    "developer-tools",
    "vibe-engineer"
  ]
}
