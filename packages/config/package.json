{
  "name": "@vibe-engineer/config",
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "description": "Strict project configuration defaults, schema validation, and loaders for vibe-engineer.",
  "private": false,
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.33.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismailsaleekh/vibe-engineer.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node tests/run-tests.mjs",
    "lint": "eslint .",
    "build": "tsup"
  },
  "vibeEngineer": {
    "implementationUnit": "I-01B-config-loader",
    "implementationStatus": "v0.1-public-config-api",
    "packageRole": "public-config-package",
    "sourceStatus": "v0.1-config-loader-api"
  },
  "author": "Ismail <ismailsalikhodjaev@gmail.com>",
  "bugs": {
    "url": "https://github.com/ismailsaleekh/vibe-engineer/issues"
  },
  "homepage": "https://github.com/ismailsaleekh/vibe-engineer#readme",
  "keywords": [
    "ai",
    "agents",
    "typescript",
    "verification",
    "schematics",
    "developer-tools",
    "vibe-engineer"
  ]
}
