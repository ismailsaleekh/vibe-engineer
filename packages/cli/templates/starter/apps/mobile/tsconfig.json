{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "jsx": "react-jsx",
    "types": ["react"],
    "baseUrl": ".",
    "paths": {
      "react-native": ["src/types/react-native-shims.d.ts"],
      "@react-navigation/native": ["src/types/react-native-shims.d.ts"],
      "@react-navigation/native-stack": ["src/types/react-native-shims.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
