{
  "services": {
    "postgres": {
      "image": "postgres:17-alpine",
      "environment": {
        "POSTGRES_USER": "starter_local",
        "POSTGRES_PASSWORD": "starter_local",
        "POSTGRES_DB": "starter_dev"
      },
      "ports": ["5432:5432"],
      "healthcheck": {
        "test": ["CMD-SHELL", "pg_isready -U starter_local -d starter_dev"],
        "interval": "5s",
        "timeout": "5s",
        "retries": 10
      },
      "volumes": ["postgres-data:/var/lib/postgresql/data"]
    }
  },
  "volumes": {
    "postgres-data": {}
  }
}
