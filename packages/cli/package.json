{
  "name": "vibe-engineer",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "description": "v0.1 deterministic CLI primitives, starter generator, and public runtime assets for vibe-engineer.",
  "bin": {
    "vibe-engineer": "./dist/entry/vibe-engineer.js"
  },
  "exports": {
    ".": {
      "types": "./dist/entry/vibe-engineer.d.ts",
      "import": "./dist/entry/vibe-engineer.js"
    },
    "./envelope": {
      "types": "./dist/envelope/result-envelope.d.ts",
      "import": "./dist/envelope/result-envelope.js"
    },
    "./command-loader": {
      "types": "./dist/command-loader/loader.d.ts",
      "import": "./dist/command-loader/loader.js"
    }
  },
  "files": [
    "dist",
    "templates/starter/**",
    "templates/pi/**",
    "templates/starter.layout.json"
  ],
  "scripts": {
    "build": "node scripts/copy-templates.mjs && tsup && node scripts/copy-types.mjs",
    "test": "node src/testing/run-witnesses.mjs"
  },
  "vibeEngineer": {
    "implementationUnit": "I-02A-cli-loader-envelope",
    "implementationStatus": "v0.1-release-runtime",
    "packageRole": "public-cli-package",
    "sourceStatus": "v0.1-public-commands-and-starter-assets-wired",
    "binStatus": "dist-bin-proven-by-pack-install-smoke"
  },
  "private": false,
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.33.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismailsaleekh/vibe-engineer.git"
  },
  "dependencies": {
    "@vibe-engineer/adapter-pi": "^0.1.0",
    "@vibe-engineer/artifacts": "^0.1.0",
    "@vibe-engineer/config": "^0.1.0",
    "@vibe-engineer/skills": "^0.1.0",
    "@vibe-engineer/context": "^0.1.0",
    "@vibe-engineer/security": "^0.1.0",
    "@vibe-engineer/schematics": "^0.1.0",
    "@vibe-engineer/verification": "^0.1.0"
  },
  "author": "Ismail <ismailsalikhodjaev@gmail.com>",
  "bugs": {
    "url": "https://github.com/ismailsaleekh/vibe-engineer/issues"
  },
  "homepage": "https://github.com/ismailsaleekh/vibe-engineer#readme",
  "keywords": [
    "ai",
    "agents",
    "typescript",
    "verification",
    "schematics",
    "developer-tools",
    "vibe-engineer"
  ]
}
