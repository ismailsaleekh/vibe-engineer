{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-engineer.dev/quality/v1/quality-summary.schema.json",
  "title": "QualitySummaryV1",
  "description": "Summary JSON emitted by the I-20A local quality runner (pnpm quality). Aggregates the fail-closed wiring verdict and the real per-tier aggregate results.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "profile",
    "generatedAt",
    "projectRoot",
    "evidenceDir",
    "wiring",
    "tiers",
    "overallOk",
    "exitCode"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "quality.summary/1" },
    "profile": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "minLength": 1 },
    "projectRoot": { "type": "string", "minLength": 1 },
    "evidenceDir": { "type": "string", "minLength": 1 },
    "wiring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verdict",
        "expectedFamilies",
        "registeredAndRunningFamilies",
        "missingFamilies",
        "evidenceFile"
      ],
      "properties": {
        "verdict": { "type": "string", "enum": ["pass", "fail"] },
        "expectedFamilies": {
          "type": "array",
          "items": { "type": "string", "pattern": "^p\\d+$" }
        },
        "registeredAndRunningFamilies": {
          "type": "array",
          "items": { "type": "string", "pattern": "^p\\d+$" }
        },
        "missingFamilies": { "type": "array", "items": { "type": "string", "pattern": "^p\\d+$" } },
        "evidenceFile": { "type": "string", "minLength": 1 }
      }
    },
    "tiers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "family",
          "exportName",
          "registered",
          "running",
          "carrierFamily",
          "ok",
          "findingCount",
          "blockingFindingCount",
          "evidenceFile"
        ],
        "properties": {
          "family": { "type": "string", "pattern": "^p\\d+$" },
          "exportName": { "type": "string", "pattern": "^runP\\d+Aggregate$" },
          "registered": { "type": "boolean" },
          "running": { "type": "boolean" },
          "carrierFamily": {
            "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
          },
          "ok": { "type": "boolean" },
          "findingCount": { "type": "integer" },
          "blockingFindingCount": { "type": "integer" },
          "implementedFamilies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "evidenceFile": {
            "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
          },
          "runError": {
            "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
          }
        }
      }
    },
    "overallOk": { "type": "boolean" },
    "exitCode": { "type": "integer" },
    "skippedCategoryDiagnostic": {
      "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
    }
  }
}
