# Dependencies
node_modules/
.pnpm-store/

# Build outputs
# NOTE: this repo's build-output contract is dist/** (see turbo.json tasks.build.outputs).
# The bare `build/` rule was removed because it only matched source dirs
# (e.g. packages/cli/src/commands/build/, packages/skills/src/build/), not build artifacts.
dist/
coverage/
.turbo/
*.tsbuildinfo

# Logs and diagnostics
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment and local machine files
.env
.env.*
!.env.example
.DS_Store
Thumbs.db

# Editor caches
.idea/
.vscode/

# Agent harness local session logs (generated by pi, not project content)
.pi/tasks/

# Regenerable validation scratch
**/transient-caches/
**/transient-workspaces/
