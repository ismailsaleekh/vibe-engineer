# Dependencies
node_modules/
.pnpm-store/

# Build outputs
# NOTE: this repo's build-output contract is dist/** (see turbo.json tasks.build.outputs).
# The bare `build/` rule was removed because it only matched source dirs
# (e.g. packages/cli/src/commands/build/, packages/skills/src/build/), not build artifacts.
dist/
coverage/
.turbo/
*.tsbuildinfo
*.map

# Logs and diagnostics
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment and local machine files
.env
.env.*
!.env.example
!examples/starter-reference/.source-template/.env
!examples/starter-reference/.source-template/apps/api/.env
!packages/cli/templates/starter/.env
!packages/cli/templates/starter/apps/api/.env
.DS_Store
Thumbs.db

# Editor caches
.idea/
.vscode/

# Agent harness local session logs/runtime state (generated by pi/autopilot, not project content)
.pi/tasks/
.pi/autopilot/
/autopilot/

# Regenerable validation scratch
**/transient-caches/
**/transient-workspaces/

# VitePress dependency pre-bundle cache (regenerable)
.vitepress/cache/
# Regenerable Turbo validation caches
.turbo-*

# One-off bundled/transpiled config scratch files
**/tsup.config.bundled_*.mjs

# Local release evidence and package tarballs (regenerable)
.vibe/release/

# Regenerable mechanical-gate/test evidence emitted by local quality runs
.vibe/work/I-02A-cli-loader-envelope/evidence/fix/package-test-*/
.vibe/work/I-12-mechanical-P1-ratchet-test-scanner/aggregate/i11-bridge-artifacts/run-*/
.vibe/work/I-13C-p2-aggregate-runner-bridge/aggregate/code-smell-bridge-artifacts/run-*/

