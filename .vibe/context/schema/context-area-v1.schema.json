{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vibe-engineer.dev/context/v1/context-area.schema.json",
  "title": "ContextAreaV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactKind", "areaId", "title", "owner", "level", "mandatory", "sourceRefs", "context", "scope", "updateMetadata", "driftMetadata", "schemaRef"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "artifactKind": { "const": "context_area" },
    "areaId": { "$ref": "#/$defs/nonEmptyString" },
    "title": { "$ref": "#/$defs/nonEmptyString" },
    "owner": { "$ref": "#/$defs/nonEmptyString" },
    "level": { "$ref": "#/$defs/level" },
    "mandatory": { "type": "boolean" },
    "sourceRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } },
    "context": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/contextItem" } },
    "scope": { "$ref": "#/$defs/scope" },
    "updateMetadata": { "$ref": "#/$defs/updateMetadata" },
    "driftMetadata": { "$ref": "#/$defs/driftMetadata" },
    "schemaRef": { "const": "https://schemas.vibe-engineer.dev/context/v1/context-area.schema.json" }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "level": { "type": "integer", "minimum": 0, "maximum": 4 },
    "scope": { "type": "object", "additionalProperties": false, "required": ["kind", "paths", "description"], "properties": { "kind": { "$ref": "#/$defs/nonEmptyString" }, "paths": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } }, "description": { "$ref": "#/$defs/nonEmptyString" } } },
    "typedContent": { "type": "object", "additionalProperties": false, "required": ["kind", "value"], "properties": { "kind": { "$ref": "#/$defs/nonEmptyString" }, "value": {} } },
    "contextItem": { "type": "object", "additionalProperties": false, "required": ["contextId", "level", "mandatory", "sourceRefs", "citationRefs"], "anyOf": [{ "required": ["text"], "properties": { "text": { "$ref": "#/$defs/nonEmptyString" } } }, { "required": ["content"], "properties": { "content": { "$ref": "#/$defs/typedContent" } } }], "properties": { "contextId": { "$ref": "#/$defs/nonEmptyString" }, "level": { "$ref": "#/$defs/level" }, "mandatory": { "type": "boolean" }, "text": { "$ref": "#/$defs/nonEmptyString" }, "content": { "$ref": "#/$defs/typedContent" }, "sourceRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } }, "citationRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } } } },
    "updateMetadata": { "type": "object", "additionalProperties": false, "required": ["invalidationStatus"], "properties": { "invalidationStatus": { "$ref": "#/$defs/nonEmptyString" } } },
    "driftMetadata": { "type": "object", "additionalProperties": false, "required": ["driftStatus", "sourceRefs"], "properties": { "driftStatus": { "$ref": "#/$defs/nonEmptyString" }, "sourceRefs": { "type": "array", "items": { "$ref": "#/$defs/nonEmptyString" } } } }
  }
}
