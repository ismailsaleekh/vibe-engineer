$ node --input-type=module -e "import {readFileSync,readdirSync,existsSync} from 'node:fs'; import {join} from 'node:path'; const roots=['package.json',...readdirSync('packages').map(p=>join('packages',p,'package.json')).filter(existsSync)]; const offenders=[]; for (const p of roots){ const j=JSON.parse(readFileSync(p,'utf8')); if (j.dependencies && Object.prototype.hasOwnProperty.call(j.dependencies,'@vibe-engineer/testing')) offenders.push(p);} console.log(JSON.stringify({ok: offenders.length===0, offenders})); process.exit(offenders.length===0?0:1);"
{"ok":true,"offenders":[]}

__EXIT__:0
