{
  "command": {
    "command": "node examples/starter-reference/generated-fixtures/security/runner/security-hook-runner.mjs",
    "argv": [
      "examples/starter-reference/generated-fixtures/security/requests/safe-local-read-only-command.json"
    ],
    "classification": "read_only",
    "workingDirectory": "examples/starter-reference/generated-fixtures/security",
    "targetPaths": [
      "examples/starter-reference/generated-fixtures/security/requests/safe-local-read-only-command.json"
    ]
  },
  "env": {
    "NODE_ENV": "test",
    "VIBE_ENGINEER_MODE": "local"
  },
  "config": {
    "externalIntegrationEnabled": false,
    "localFixtureMode": true
  },
  "externalIntegrations": [
    {
      "id": "local-fixture-only",
      "mode": "local_fixture",
      "enabled": false,
      "requiresCredential": false,
      "requiresBudget": false,
      "requiresNetwork": false,
      "networkMutation": false,
      "explicitApproval": false
