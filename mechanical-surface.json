    { "kind": "prefix", "path": ".github", "tools": ["prettier"] },
    { "kind": "exact", "path": "eslint.config.mjs", "tools": ["eslint"] },
    { "kind": "exact", "path": "prettier.config.mjs", "tools": ["prettier"] },
    { "kind": "exact", "path": "package.json", "tools": ["pnpm"] },
    { "kind": "exact", "path": "tsconfig.json", "tools": ["tsc"] },
    { "kind": "exact", "path": "tsconfig.base.json", "tools": ["tsc"] },
    { "kind": "exact", "path": "turbo.json", "tools": ["turbo"] },
    { "kind": "exact", "path": "pnpm-workspace.yaml", "tools": ["pnpm"] },
    { "kind": "exact", "path": "mechanical-boundaries.json", "tools": ["mechanical-gates"] },
    { "kind": "exact", "path": "mechanical-escape-allowlist.json", "tools": ["mechanical-gates"] },
    { "kind": "exact", "path": "mechanical-domain-purity.json", "tools": ["mechanical-gates"] },
    { "kind": "exact", "path": "mechanical-testing-boundary.json", "tools": ["mechanical-gates"] },
    { "kind": "exact", "path": "README.md", "tools": ["markdownlint"] },
    { "kind": "exact", "path": "CHANGELOG.md", "tools": ["markdownlint"] },
    { "kind": "exact", "path": "CODE_OF_CONDUCT.md", "tools": ["markdownlint"] },
    { "kind": "exact", "path": "CONTRIBUTING.md", "tools": ["markdownlint"] },
    { "kind": "exact", "path": "SECURITY.md", "tools": ["markdownlint"] }
